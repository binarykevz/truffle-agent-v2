# ===== Main Database (users, config, history) =====
TURSO_DATABASE_URL=libsql://main-db-your-org.turso.io
TURSO_AUTH_TOKEN=your-main-db-auth-token

# ===== Commands Database (isolated feature code) =====
TURSO_COMMANDS_DATABASE_URL=libsql://commands-db-your-org.turso.io
TURSO_COMMANDS_AUTH_TOKEN=your-commands-db-auth-token

# ===== Fixed Owner =====
# ONLY this Telegram user ID can run admin commands.
OWNER_ID=6076887662

# ===== Bot Token (auto-seeded into DB on first boot) =====
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
