# ===== Turso Database =====
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ===== Fixed Owner =====
# ONLY this Telegram user ID can run admin commands.
# Change this value to transfer ownership.
OWNER_ID=6076887662

# ===== Bot Token (seeded into Turso on first boot if missing) =====
# You can either seed it manually into Turso, or set it here and the
# bot will auto-seed it on first boot.
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
